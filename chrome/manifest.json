{
  "manifest_version": 3,
  "name": "tabsnap — capture all your tabs in one click",
  "short_name": "tabsnap",
  "version": "1.0.0",
  "description": "Capture every open tab as plain text, markdown, JSON, or a readme file. One click to share your tab graveyard. Free.",
  "homepage_url": "https://extensions.voiddo.com/tabsnap/",
  "author": "vøiddo",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "tabsnap — capture all open tabs",
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "tabs",
    "downloads",
    "storage"
  ],
  "minimum_chrome_version": "110"
}
